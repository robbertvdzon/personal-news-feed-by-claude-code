# Cluster-secrets bron-file voor seal-secrets.sh.
# Kopieer dit bestand naar `secrets-cluster.env` en vul de échte waarden
# in. Die kopie is gitignored — alleen op jouw laptop.
#
# Wat hier in deze file komt:
#   - keys die de backend nodig heeft als env-var
#   - waarden VOOR DE CLUSTER (kunnen anders zijn dan jouw lokale .env!)
#
# Belangrijk: na elke aanpassing run je ./seal-secrets.sh en commit
# je de geregenereerde sealed-secret-api-keys.yaml. De file hier
# verlaat je laptop niet.

# Database (Postgres via Neon of een aparte prod-DB)
DATABASE_URL=jdbc:postgresql://your-cluster-db.neon.tech/neondb?user=...&password=...&sslmode=require

# JWT signing key (>=32 chars). Genereer eentje met `openssl rand -base64 48`.
JWT_SECRET=

# AI providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...
ELEVENLABS_API_KEY=sk_...
