# Cluster-secrets bron-file voor seal-secrets.sh.
# Kopieer dit bestand naar `secrets-cluster.env` en vul de échte waarden
# in. Die kopie is gitignored — alleen op jouw laptop.
#
# Wat hier in deze file komt:
#   - keys die de backend nodig heeft als env-var
#   - waarden VOOR DE CLUSTER (kunnen anders zijn dan jouw lokale .env!)
#
# Belangrijk: na elke aanpassing run je ./seal-secrets.sh en commit
# je de geregenereerde sealed-secret-api-keys.yaml. De file hier
# verlaat je laptop niet.

# Database (Postgres via Neon of een aparte prod-DB)
PNF_DATABASE_URL=jdbc:postgresql://your-cluster-db.neon.tech/neondb?user=...&password=...&sslmode=require

# JWT signing key (>=32 chars). Genereer eentje met `openssl rand -base64 48`.
JWT_SECRET=

# AI providers
PNF_ANTHROPIC_API_KEY=sk-ant-...
PNF_OPENAI_API_KEY=sk-proj-...
PNF_TAVILY_API_KEY=tvly-...
PNF_ELEVENLABS_API_KEY=sk_...

# Claude Code OAuth-token voor de runner-Jobs. Genereer eenmalig met
# `claude setup-token` op je laptop (~1 jaar geldig, gekoppeld aan je
# Max-abonnement). Routeert runner-usage via je Max-quotum i.p.v.
# API-billing. NIET gebruiken voor de backend.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Cloudflare Tunnel token — Zero Trust → Networks → Tunnels → Cloudflared
# Geeft de tunnel-pod uitgaande toegang tot Cloudflare zodat
# news.vdzonsoftware.nl naar de cluster-frontend gerouteerd wordt.
TUNNEL_TOKEN=eyJ...
